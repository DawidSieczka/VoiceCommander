<Window x:Class="VoiceTypePL.App.Editing.SelectionHighlightWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowActivated="False"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        IsHitTestVisible="False"
        WindowStartupLocation="Manual">

    <!-- Ramka wokół zaznaczonego zdania (§5.6.4). Półprzezroczyste wypełnienie + wyraźny obrys. -->
    <Border BorderBrush="#4CAF50" BorderThickness="2" CornerRadius="3" Background="#334CAF50" />
</Window>
